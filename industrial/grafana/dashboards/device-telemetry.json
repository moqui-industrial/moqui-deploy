          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "moqui-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 'Parameter series' AS metric, COUNT(DISTINCT pl.parameter_id) AS value\nFROM parameter_log pl\nJOIN parameter p ON p.parameter_id = pl.parameter_id\nWHERE p.device_id = '${device_id}'\n  AND $__timeFilter(pl.observed_date)\nUNION ALL\nSELECT 'Measurement series' AS metric, COUNT(DISTINCT CONCAT_WS('|', m.measurement_type_id, COALESCE(m.work_effort_id, m.asset_id, m.facility_id, m.product_id, m.reason_enum_id, m.product_meter_id, m.asset_maintenance_id, 'unscoped'))) AS value\nFROM measurement m\nWHERE $__timeFilter(m.measurement_date)\n  AND (\n    m.work_effort_id = '${device_id}' OR\n    m.asset_id = '${device_id}' OR\n    m.facility_id = '${device_id}' OR\n    m.product_id = '${device_id}' OR\n    m.reason_enum_id = '${device_id}' OR\n    m.product_meter_id = '${device_id}' OR\n    m.asset_maintenance_id = '${device_id}'\n  )\nUNION ALL\nSELECT 'Device logs' AS metric, COUNT(*) AS value\nFROM device_log dl\nWHERE dl.device_id = '${device_id}'\n  AND $__timeFilter(dl.observed_date);",
          "refId": "A"
        }
      ],
      "title": "Coverage",
      "type": "table"
    },
