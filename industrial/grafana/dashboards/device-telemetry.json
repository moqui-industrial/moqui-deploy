          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (metric)\n  metric AS \"Series\",\n  measurement_date AS \"Observed\",\n  measurement_value AS \"Value\"\nFROM (\n  SELECT\n    m.measurement_date,\n    m.measurement_value,\n    CONCAT_WS(' / ', m.measurement_type_id, COALESCE(m.work_effort_id, m.asset_id, m.facility_id, m.product_id, m.reason_enum_id, m.product_meter_id, m.asset_maintenance_id, 'unscoped')) AS metric\n  FROM measurement m\n  WHERE $__timeFilter(m.measurement_date)\n    AND (\n      m.work_effort_id = '${device_id}' OR\n      m.asset_id = '${device_id}' OR\n      m.facility_id = '${device_id}' OR\n      m.product_id = '${device_id}' OR\n      m.reason_enum_id = '${device_id}' OR\n      m.product_meter_id = '${device_id}' OR\n      m.asset_maintenance_id = '${device_id}'\n    )\n) latest\nORDER BY metric, measurement_date DESC;",
          "refId": "A"
        }
      ],
