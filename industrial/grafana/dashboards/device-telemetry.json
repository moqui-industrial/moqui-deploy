          "rawQuery": true,
          "rawSql": "SELECT\n  pl.observed_date AS \"Observed\",\n  pl.sequence_num AS \"Seq\",\n  pl.parameter_id AS \"Parameter ID\",\n  COALESCE(pd.parameter_name, p.parameter_id) AS \"Parameter\",\n  pl.numeric_value AS \"Numeric\",\n  pl.symbolic_value AS \"Symbolic\",\n  pl.parameter_enum_id AS \"Enum\"\nFROM parameter_log pl\nJOIN parameter p ON p.parameter_id = pl.parameter_id\nLEFT JOIN parameter_def pd ON pd.parameter_def_id = p.parameter_def_id\nWHERE $__timeFilter(pl.observed_date)\n  AND p.device_id = '${device_id}'\nORDER BY pl.observed_date DESC\nLIMIT 200;",
