          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  pl.observed_date AS \"time\",\n  COALESCE(pd.parameter_name, p.parameter_id) AS metric,\n  pl.numeric_value AS value\nFROM parameter_log pl\nJOIN parameter p ON p.parameter_id = pl.parameter_id\nLEFT JOIN parameter_def pd ON pd.parameter_def_id = p.parameter_def_id\nWHERE $__timeFilter(pl.observed_date)\n  AND p.device_id = '${device_id}'\n  AND pl.numeric_value IS NOT NULL\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "ParameterLog Numeric Series",
      "type": "timeseries"
